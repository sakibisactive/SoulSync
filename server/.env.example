PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/partner_match
JWT_SECRET=super_secret_jwt_key_partner_match_2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=super_secret_refresh_key_partner_match_2026
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173

# Cloudinary Configuration (Optional for Cloud uploads)
CLOUDINARY_CLOUD_NAME=demo_cloud
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=secret_key

# Email Service Configuration (Brevo / SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_email@example.com
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=noreply@partnermatch.com
